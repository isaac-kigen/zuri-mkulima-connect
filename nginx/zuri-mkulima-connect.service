# ============================================================
# Systemd Service — Zuri Mkulima Connect (Next.js)
# ============================================================
# Place at: /etc/systemd/system/zuri-mkulima-connect.service
#
# Commands:
#   sudo systemctl daemon-reload
#   sudo systemctl enable zuri-mkulima-connect
#   sudo systemctl start zuri-mkulima-connect
#   sudo systemctl status zuri-mkulima-connect
# ============================================================

[Unit]
Description=Zuri Mkulima Connect — Next.js Application
Documentation=https://trader.ketronics.co.ke
After=network.target postgresql.service redis.service
Wants=network.target

[Service]
Type=simple
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/ubuntu/projects/deepseek_agent/work/mkulima_connect
Environment="NODE_ENV=production"
Environment="PORT=3000"
Environment="HOSTNAME=127.0.0.1"

# Start Next.js production server
ExecStart=/usr/bin/node /home/ubuntu/projects/deepseek_agent/work/mkulima_connect/node_modules/next/dist/bin/next start -p 3000 -H 127.0.0.1

# Restart policy
Restart=always
RestartSec=5

# Limits
LimitNOFILE=65536
LimitNPROC=32768

# Logging
StandardOutput=append:/var/log/zuri-mkulima-connect/stdout.log
StandardError=append:/var/log/zuri-mkulima-connect/stderr.log
SyslogIdentifier=zuri-mkulima-connect

[Install]
WantedBy=multi-user.target
